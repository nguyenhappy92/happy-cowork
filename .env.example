# Copy to ~/.env (or load via direnv) and fill in real values.
# Never commit the actual .env file.

# GitHub personal access token used by MCP and gh CLI fallbacks.
GITHUB_TOKEN=

# Linear API key for the Linear MCP server.
LINEAR_API_KEY=

# Datadog (if using the Datadog MCP plugin).
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
